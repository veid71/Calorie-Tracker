<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:clipToPadding="false"
        android:fitsSystemWindows="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/surface_elevated"
            android:elevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvCaloriesConsumed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textColor="@color/primary_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/"
                        android:textSize="28sp"
                        android:textColor="@color/text_secondary"
                        android:layout_gravity="center_vertical" />

                    <TextView
                        android:id="@+id/tvDailyGoal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2000"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/calories_consumed"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/progressBarCalories"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="12dp"
                    android:progressDrawable="@drawable/progress_bar_modern"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/tvCaloriesRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="2000 calories remaining"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_secondary" />

                <!-- Workout Bonus with Info Icon -->
                <LinearLayout
                    android:id="@+id/layoutWorkoutBonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">
                    
                    <TextView
                        android:id="@+id/tvWorkoutBonus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/accent_orange" />
                    
                    <ImageView
                        android:id="@+id/ivWorkoutInfo"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_info_outline"
                        android:tint="@color/text_secondary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="2dp"
                        android:contentDescription="@string/workout_info_description" />
                        
                </LinearLayout>

                <TextView
                    android:id="@+id/tvVersionInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Loading version..."
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary"
                    android:alpha="0.7" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Workout Summary Widget -->
        <com.calorietracker.widgets.WorkoutSummaryWidget
            android:id="@+id/workoutSummaryWidget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Health Metrics Widget -->
        <com.calorietracker.widgets.HealthMetricsWidget
            android:id="@+id/healthMetricsWidget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- Quick Favorites Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuickFavorites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_elevated"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ Quick Add Favorites"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_gravity="center_vertical" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSeeAllFavorites"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="See All"
                        android:textSize="11sp"
                        android:textColor="@color/primary_green"
                        android:backgroundTint="@android:color/transparent"
                        style="@style/Widget.Material3.Button.TextButton"
                        app:cornerRadius="8dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerFavorites"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal" />

                <TextView
                    android:id="@+id/tvNoFavorites"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:text="No favorites yet!\nAdd foods to your favorites by long-pressing entries in your history."
                    android:textAlignment="center"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Streak card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStreak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/primary_green">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="24sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tvStreakCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 day streak"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tvStreakSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log today to start your streak!"
                        android:textSize="12sp"
                        android:textColor="#CCFFFFFF" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManualEntry"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="@string/manual_entry"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary_green"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_add"
                app:iconSize="20dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanBarcode"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/scan_barcode"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_orange"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_scan"
                app:iconSize="20dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewHistory"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="@string/view_history"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary_green"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_history"
                app:iconSize="18dp"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNutritionDashboard"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Nutrition"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_blue"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_nutrition"
                app:iconSize="20dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnalytics"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Analytics"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_purple"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_analytics"
                app:iconSize="20dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/settings"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/text_secondary"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_settings"
                app:iconSize="18dp"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <!-- Additional Features Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWaterTracking"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Water"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_blue"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_water_drop"
                app:iconSize="20dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWeightTracking"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Weight"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_orange"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_scale"
                app:iconSize="20dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <!-- Recipe Features Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateRecipe"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Create Recipe"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary_green"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_add"
                app:iconSize="18dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecipeLibrary"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Recipe Library"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_orange"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_gallery"
                app:iconSize="18dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <!-- More Features Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMealPlanner"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Meal Planner"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_purple"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_nutrition"
                app:iconSize="18dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShoppingList"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Shopping List"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary_green"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_add"
                app:iconSize="18dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <!-- Voice + Progress Photos Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoiceInput"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Voice Input"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_orange"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_analytics"
                app:iconSize="18dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProgressPhotos"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Progress Photos"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_orange"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_camera"
                app:iconSize="18dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:elevation="4dp" />

        </LinearLayout>

        <!-- Developer Debug Row (debug builds only, hidden at runtime in release) -->
        <LinearLayout
            android:id="@+id/layoutDebugRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestWorkout"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Test Workout"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/success_green"
                app:cornerRadius="12dp"
                android:elevation="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTestOpenFoodFacts"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="Test Food DB"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/accent_blue"
                app:cornerRadius="12dp"
                android:elevation="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUIDebug"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="UI Debug"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/red"
                app:cornerRadius="12dp"
                android:elevation="2dp" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/surface_elevated"
            android:elevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Entries"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewTodayEntries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvNoEntries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="No entries for today"
                    android:textAlignment="center"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>