<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    tools:context=".NutritionDashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clipToPadding="false"
        android:fitsSystemWindows="true">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nutrition Dashboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/dark_gray"
                android:gravity="center"
                android:layout_gravity="center_vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Quick Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddFood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Add Food"
            android:backgroundTint="@color/primary_green" />

        <!-- Calories Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvCaloriesConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvCaloriesGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 2000 cal"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvCaloriesPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarCalories"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Protein Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protein"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvProteinConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvProteinGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 50g"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvProteinPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarProtein"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Carbohydrates Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carbohydrates"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvCarbsConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvCarbsGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 300g"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvCarbsPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarCarbs"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Fat Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fat"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvFatConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvFatGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 65g"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvFatPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarFat"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Fiber Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fiber"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvFiberConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvFiberGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 25g"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvFiberPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarFiber"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Sugar Card (Warning - this is a limit) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSugar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sugar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="(Limit)"
                        android:textSize="12sp"
                        android:textColor="@color/orange"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvSugarConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvSugarLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 50g"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvSugarPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarSugar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Sodium Card (Warning - this is a limit) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSodium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sodium"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="(Limit)"
                        android:textSize="12sp"
                        android:textColor="@color/orange"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvSodiumConsumed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0mg"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_gray" />

                    <TextView
                        android:id="@+id/tvSodiumLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 2300mg"
                        android:textSize="16sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/tvSodiumPercentage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarSodium"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>