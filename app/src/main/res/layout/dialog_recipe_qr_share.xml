<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share Recipe"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green" />

            <Button
                android:id="@+id/btnClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="✕"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:textColor="@color/dark_gray" />

        </LinearLayout>

        <!-- Recipe Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary_green"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvRecipeName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recipe Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share this recipe with friends and family using QR code or text"
                    android:textSize="14sp"
                    android:textColor="@color/dark_gray" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- QR Code Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/accent_orange"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 QR Code"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_orange"
                    android:layout_marginBottom="12dp" />

                <ImageView
                    android:id="@+id/ivQRCode"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:background="@color/white"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Recipe QR Code"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Long press QR code to copy link"
                    android:textSize="12sp"
                    android:textColor="@color/medium_gray"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvShareLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Generating link..."
                    android:textSize="12sp"
                    android:textColor="@color/dark_gray"
                    android:background="@color/light_gray"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Sharing Options -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/primary_green"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚀 Sharing Options"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"
                    android:layout_marginBottom="16dp" />

                <!-- Share Link Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔗 Share Recipe Link"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    app:backgroundTint="@color/primary_green"
                    app:cornerRadius="8dp"
                    android:textColor="@color/white" />

                <!-- Share Full Recipe Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📄 Share Full Recipe Text"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    app:backgroundTint="@color/accent_orange"
                    app:cornerRadius="8dp"
                    android:textColor="@color/white" />

                <!-- Save QR Code Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveQR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💾 Save QR Code to Gallery"
                    android:textSize="16sp"
                    app:backgroundTint="@color/medium_gray"
                    app:cornerRadius="8dp"
                    android:textColor="@color/white"
                    android:enabled="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>