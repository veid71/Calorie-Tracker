<?xml version="1.0" encoding="utf-8"?>
<!-- 👨‍🍳 COMMUNITY RECIPES FRAGMENT LAYOUT - RECIPE SHARING SOCIAL NETWORK -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 📱 HEADER WITH SEARCH AND ACTIONS -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 👨‍🍳 TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👨‍🍳 Community Recipes"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <!-- 🔍 SEARCH BAR -->
            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:hint="🔍 Search recipes... (e.g., 'high protein lunch')"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:singleLine="true" />

            <!-- 🎛️ CATEGORY AND ACTIONS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- 🏷️ CATEGORY SELECTOR -->
                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/spinner_background"
                    android:layout_marginEnd="8dp" />

                <!-- 📝 SUBMIT RECIPE BUTTON -->
                <Button
                    android:id="@+id/submitRecipeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="📝 Submit"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_green"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- 📦 MY RECIPE BOX BUTTON -->
                <Button
                    android:id="@+id/myRecipeBoxButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="📦 My Box"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface_secondary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 🎛️ FILTER CONTROLS -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:id="@+id/filterChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 🎛️ FILTER TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎛️ Filters"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <!-- 🔍 FILTER CHECKBOXES ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/featuredOnlyCheckbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌟 Featured"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/highProteinCheckbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💪 High Protein"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/lowCarbCheckbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🥗 Low Carb"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- 🔍 FILTER CHECKBOXES ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/quickMealsCheckbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ Quick (30min)"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <CheckBox
                    android:id="@+id/vegetarianOnlyCheckbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌱 Vegetarian"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <!-- 📊 SPACER FOR ALIGNMENT -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 📋 RECIPE LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recipesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
</LinearLayout>