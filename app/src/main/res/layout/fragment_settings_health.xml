<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Health Connect Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fitness Integration"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connect your OnePlus Watch 3 to automatically adjust calorie goals based on workouts"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="16dp" />

                <!-- Health Connect Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Health Connect Status"
                            android:textSize="16sp"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvHealthConnectStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Checking..."
                            android:textSize="12sp"
                            android:textColor="@color/black" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvHealthConnectIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚪"
                        android:textSize="20sp"
                        android:layout_gravity="center_vertical" />

                </LinearLayout>

                <!-- Setup Health Connect Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetupHealthConnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Setup OnePlus Watch Integration"
                    android:backgroundTint="@color/accent_orange"
                    android:layout_marginBottom="8dp" />

                <!-- Sync Workout Data Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSyncWorkoutData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sync Workout Data Now"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:enabled="false"
                    android:layout_marginBottom="8dp" />

                <!-- Debug Health Connect Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHealthConnectDebug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Verify Sync Status"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="@color/accent_blue" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>