<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Regional Settings Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Regional Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose your region to get appropriate food databases and nutrition recommendations"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="16dp" />

                <!-- Region Selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Region"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerRegion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:popupBackground="@color/white"
                    style="@android:style/Widget.Spinner.DropDown" />

                <!-- Update Food Database Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdateFoodDatabase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Update Food Database for Selected Region"
                    android:layout_marginBottom="8dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <!-- Download Full Database Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadFullDatabase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Download Full Food Databases (USDA + Open Food Facts)"
                    android:backgroundTint="@color/primary_green"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp"
                    app:icon="@drawable/ic_download"
                    app:iconSize="18dp" />

                <!-- Database Status -->
                <TextView
                    android:id="@+id/tvDatabaseStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Local database: checking..."
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:alpha="0.6"
                    android:layout_marginBottom="8dp"
                    android:drawablePadding="6dp" />

                <!-- Test Notification Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestNotification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔔 Test Notification System"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.TextButton" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>