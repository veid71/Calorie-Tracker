<?xml version="1.0" encoding="utf-8"?>
<!-- 📱 SHARE PROGRESS FRAGMENT LAYOUT - SOCIAL SHARING HUB -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:spacing="16dp">

        <!-- 📱 HEADER SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 📱 TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 Share Your Progress"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <!-- 💡 MOTIVATIONAL QUOTE -->
                <TextView
                    android:id="@+id/motivationalQuoteText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌟 Progress, not perfection, is the goal!"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="italic"
                    android:layout_marginBottom="16dp" />

                <!-- 👀 PREVIEW -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👀 Preview"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/previewTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Preview will appear here..."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:background="@color/surface_secondary"
                    android:padding="12dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 📊 SHARING OPTIONS SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 📊 SECTION TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 What to Share"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- 📊 SHARING BUTTONS GRID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:spacing="12dp">

                    <!-- 📊 DAILY SUMMARY BUTTON -->
                    <Button
                        android:id="@+id/shareDailySummaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="📊 Share Today's Summary"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary_green"
                        android:drawableStart="@drawable/ic_today"
                        android:drawablePadding="8dp"
                        style="@style/Widget.MaterialComponents.Button" />

                    <!-- 📈 WEEKLY CHART BUTTON -->
                    <Button
                        android:id="@+id/shareWeeklyChartButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="📈 Share Weekly Chart"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/accent_blue"
                        android:drawableStart="@drawable/ic_trending_up"
                        android:drawablePadding="8dp"
                        style="@style/Widget.MaterialComponents.Button" />

                    <!-- 🏆 ACHIEVEMENT BUTTON -->
                    <Button
                        android:id="@+id/shareAchievementButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="🏆 Share Achievement"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/accent_orange"
                        android:drawableStart="@drawable/ic_star"
                        android:drawablePadding="8dp"
                        style="@style/Widget.MaterialComponents.Button" />

                    <!-- 🎓 NUTRITION GRADE BUTTON -->
                    <Button
                        android:id="@+id/shareNutritionGradeButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="🎓 Share Nutrition Grade"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/accent_purple"
                        android:drawableStart="@drawable/ic_grade"
                        android:drawablePadding="8dp"
                        style="@style/Widget.MaterialComponents.Button" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🔒 PRIVACY SETTINGS SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:id="@+id/privacySettingsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 🔒 PRIVACY TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 Privacy Settings"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- 📊 INCLUDE CALORIES -->
                <CheckBox
                    android:id="@+id/includeCaloriesCheckbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Include calorie counts"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:checked="true"
                    android:layout_marginBottom="8dp" />

                <!-- 💪 INCLUDE MACROS -->
                <CheckBox
                    android:id="@+id/includeMacrosCheckbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💪 Include macro breakdown (protein/carbs/fat)"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <!-- ⚖️ INCLUDE WEIGHT -->
                <CheckBox
                    android:id="@+id/includeWeightCheckbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚖️ Include weight information"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <!-- 🎯 INCLUDE GOALS -->
                <CheckBox
                    android:id="@+id/includeGoalsCheckbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎯 Include goal progress percentages"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:checked="true"
                    android:layout_marginBottom="8dp" />

                <!-- 🔒 PRIVACY NOTE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 You control what information gets shared. Uncheck any items you want to keep private."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:background="@color/surface_secondary"
                    android:padding="12dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 📤 ADVANCED SHARING SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 📤 ADVANCED TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📤 Advanced Sharing"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- 📤 EXPORT DATA BUTTON -->
                <Button
                    android:id="@+id/exportDataButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="📤 Export Data (CSV)"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface_secondary"
                    android:drawableStart="@drawable/ic_file_download"
                    android:drawablePadding="8dp"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- ✏️ CUSTOM MESSAGE BUTTON -->
                <Button
                    android:id="@+id/customMessageButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="✏️ Create Custom Message"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/surface_secondary"
                    android:drawableStart="@drawable/ic_edit"
                    android:drawablePadding="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>