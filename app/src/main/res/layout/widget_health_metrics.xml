<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/card_elevated"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Today's Health Metrics"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvLastHealthSync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last sync: --"
            android:textSize="11sp"
            android:textColor="@color/text_hint" />

    </LinearLayout>

    <!-- Metrics Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Steps Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👟"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvStepsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="steps"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Water Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💧"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvWaterGlasses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent_blue"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="cups"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Activity Summary -->
    <LinearLayout
        android:id="@+id/containerActivitySummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏃 Activity Summary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvActivitySummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No activity data available"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- Status Messages -->
    <TextView
        android:id="@+id/tvHealthStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to sync health data"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:textAlignment="center"
        android:padding="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshHealth"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:text="Refresh"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TextButton"
            app:icon="@drawable/ic_sync"
            app:iconSize="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHealthDetails"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Details"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TextButton"
            app:icon="@drawable/ic_analytics"
            app:iconSize="16dp" />

    </LinearLayout>

</LinearLayout>